0x00]," line252="            [0x30, 0x08, 0x08, 0x10, 0x0C, 0x10, 0x08, 0x08, 0x08, 0x30, 0x00]," line253="            [0x00, 0x00, 0x00, 0x32, 0x4C, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]" line254="        ]" line255="        let line = 0" line256="        let lineStart = 0" line257="        for (let i = 0; i &lt; text.length; i++) {" line258="            if (text[i] == '\n') {" line259="                line++" line260="                lineStart = i + 1" line261="            } else if (charsetIndex.indexOf(text[i]) !== -1) {" line262="                for (let j = 0; j &lt; 11; j++) {" line263="                    for (let k = 0; k &lt; 8; k++) {" line264="                        if (charset[charsetIndex.indexOf(text[i])][j] &amp; (0x01 &lt;&lt; k)) {" line265="                            if (toggle) {" line266="                                togglePx(x + ((i - lineStart) * 8) + (8 - k), y + (line * 10) + j)" line267="                            } else {" line268="                                setPx(x + ((i - lineStart) * 8) + (8 - k), y + (line * 10) + j, color)" line269="                            }" line270="                        }" line271="                    }" line272="                }" line273="            } else if (text[i].charCodeAt(0) &lt; 128 &amp;&amp; text[i].charCodeAt(0) &gt;= 32) {" line274="                for (let l = 0; l &lt; 11; l++) {" line275="                    for (let m = 0; m &lt; 8; m++) {" line276="                        if (font[text[i].charCodeAt(0) - 32][l] &amp; (0x01 &lt;&lt; m)) {" line277="                            if (toggle) {" line278="                                togglePx(x + ((i - lineStart) * 8) + (8 - m), y + (line * 10) + l)" line279="                            } else {" line280="                                setPx(x + ((i - lineStart) * 8) + (8 - m), y + (line * 10) + l, color)" line281="                            }" line282="                        }" line283="                    }" line284="                }" line285="            } else {" line286="            }" line287="            basic.pause(1)" line288="        }" line289="    }" line290="    /**" line291="     * Draws rectangle." line292="     * You need to call `draw` to see the changes." line293="     * @param x1 coordinate x of upper left corner of rectangle (increases towards the right)" line294="     * @param y1 coordinate y of upper left corner of rectangle (increases downwards)" line295="     * @param x2 coordinate x of lower right corner of rectangle (increases towards the right)" line296="     * @param y2 coordinate y of lower right corner of rectangle (increases downwards)" line297="     * @param color color of rectangle" line298="     * @param fill sets whether only the outline or also the fill of the rectangle is drawn" line299="     * @param toggle sets whether to use pixel switching instead of setting the pixel to a specific color (if `true`, `color` means nothing)" line300="     */" line301="    //% block=&quot;draw rect at|x1 $x1|y1 $y1|x2 $x2|y2 $y2|color $color|fill $fill|toggle $toggle&quot;" line302="    //% color.defl=true" line303="    //% fill.defl=false" line304="    //% toggle.defl=false" line305="    //% weight=93" line306="    export function drawRect(x1: number, y1: number, x2: number, y2: number, color: boolean, fill: boolean, toggle: boolean): void {" line307="        if (fill) {" line308="            for (let x = x1; x &lt;= x2; x++) {" line309="                for (let y = y1; y &lt;= y2; y++) {" line310="                    if (toggle) {" line311="                        togglePx(x, y)" line312="                    } else {" line313="                        setPx(x, y, color)" line314="                    }" line315="                }" line316="            }" line317="        }" line318="        else {" line319="            for (let x2 = x1; x2 &lt;= x2; x2++) {" line320="                if (toggle) {" line321="                    togglePx(x2, y1)" line322="                } else {" line323="                    setPx(x2, y1, color)" line324="                }" line325="            }" line326="            for (let y2 = y1 + 1; y2 &lt; y2; y2++) {" line327="                if (toggle) {" line328="                    togglePx(x1, y2)" line329="                } else {" line330="                    setPx(x1, y2, color)" line331="                }" line332="            }" line333="            for (let x3 = x1; x3 &lt;= x2; x3++) {" line334="                if (toggle) {" line335="                    togglePx(x3, y2)" line336="                } else {" line337="                    setPx(x3, y2, color)" line338="                }" line339="            }" line340="            for (let y3 = y1 + 1; y3 &lt; y2; y3++) {" line341="                if (toggle) {" line342="                    togglePx(x2, y3)" line343="                } else {" line344="                    setPx(x2, y3, color)" line345="                }" line346="            }" line347="        }" line348="    }" line349="    /**" line350="     * Draws line." line351="     * You need to call `draw` to see the changes." line352="     * @param x1 coordinate x of start of line (increases towards the right)" line353="     * @param y1 coordinate y of start of line (increases downwards)" line354="     * @param x2 coordinate x of end of line (increases towards the right)" line355="     * @param y2 coordinate y of end of line (increases downwards)" line356="     * @param color color of line" line357="     * @param toggle sets whether to use pixel switching instead of setting the pixel to a specific color (if `true`, `color` means nothing)" line358="     */" line359="    //% block=&quot;draw line from|x $x1|y $y1|to|x $x2|y $y2|color $color|toggle $toggle&quot;" line360="    //% color.defl=true" line361="    //% toggle.defl=false" line362="    //% weight=92" line363="    export function drawLine(x1: number, y1: number, x2: number, y2: number, color: boolean, toggle: boolean): void {" line364="        const line2 = []" line365="        const dx = Math.abs(x2 - x1)" line366="        const dy = Math.abs(y2 - y1)" line367="        const sx = x1 &lt; x2 ? 1 : -1" line368="        const sy = y1 &lt; y2 ? 1 : -1" line369="        let err = dx - dy" line370="        while (true) {" line371="            line2.push([x1, y1])" line372="            if (x1 === x2 &amp;&amp; y1 === y2) {" line373="                break" line374="            }" line375="            const e2 = 2 * err;" line376="            if (e2 &gt; -dy) {" line377="                err -= dy" line378="                x1 += sx" line379="            }" line380="            if (e2 &lt; dx) {" line381="                err += dx" line382="                y1 += sy" line383="            }" line384="        }" line385="        for (const pixel of line2) {" line386="            if (toggle) {" line387="                togglePx(pixel[0], pixel[1])" line388="            } else {" line389="                setPx(pixel[0], pixel[1], color)" line390="            }" line391="        }" line392="    }" line393="    /**" line394="     * Draws image." line395="     * You need to call `draw` to see the changes." line396="     * @param image image to draw (can be `images.createImage()` or image from extension `imageio`)" line397="     * @param x coordinate x of upper left corner of image (increases towards the right)" line398="     * @param y coordinate y of upper left corner of image (increases downwards)" line399="     * @param color color of image (if `true`, pixel `true` in image will be drawn as `true`)" line400="     * @param bg sets whether empty pixels of the image are drawn (drawn with `not color`)" line401="     * @param toggle sets whether to use pixel switching instead of setting the pixel to a specific color (if `true`, `color` means nothing)" line402="     */" line403="    //% block=&quot;draw image|$image|x $x|y $y|color $color|background $bg|toggle $toggle&quot;" line404="    //% color.defl=true" line405="    //% bg.defl=false" line406="    //% toggle.defl=false" line407="    //% weight=100" line408="    //% advanced=true" line409="    export function drawImage(image: Image, x: number, y: number, color: boolean, bg: boolean, toggle: boolean): void {" line410="        if ((image != null) &amp;&amp; (image != undefined)) {" line411="            for (let img_y = 0; img_y &lt; image.width() * 4; img_y++) {" line412="                for (let img_x = 0; img_x &lt; image.height() * 4; img_x++) {" line413="                    let c = image.pixel(img_x, img_y)" line414="                    if ((bg &amp;&amp; !c) || (c)) {" line415="                        if (!color) {" line416="                            c = !c" line417="                        }" line418="                        for (let y_scale = 0; y_scale &lt; 4; y_scale++) {" line419="                            for (let x_scale = 0; x_scale &lt; 4; x_scale++) {" line420="                                setPx(x + img_x * 4 - x_scale + 4, y + img_y * 4 - y_scale + 4, c)" line421="                            }" line422="                        }" line423="                    }" line424="                }" line425="                basic.pause(1)" line426="            }" line427="        }" line428="    }" line429="    /**" line430="     */" line431="    //% block=&quot;image: 32x16&quot;" line432="    //% advanced=true" line433="    //% shim=images::createImage" line434="    //% imageLiteral=1 imageLiteralRows=16 imageLiteralColumns=32" line435="    export function charImage(leds: string): Image {" line436="        return &lt;Image&gt;&lt;any&gt;leds" line437="    }" line438="}" numlines="439"></mutation></block></statement></block></xml>