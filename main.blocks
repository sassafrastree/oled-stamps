<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="%za+DPDP@_Cmc,)5=bGB" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="^jB4+pmM@ilq19g2QNm("><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace oledStamp {" line1="    const ADDR = 0x3C" line2="    let screen = pins.createBuffer(1025)" line3="    let charset: number[][] = []" line4="    let charsetIndex: string[] = []" line5="" line6="    // From microbit/micropython Chinese community" line7="    function cmd1(cmd1: number): void {" line8="        let buffer = pins.createBuffer(2)" line9="        buffer[0] = 0x00" line10="        buffer[1] = cmd1" line11="        pins.i2cWriteBuffer(ADDR, buffer)" line12="    }" line13="    // From microbit/micropython Chinese community" line14="    function cmd2(cmd1: number, cmd2: number): void {" line15="        let buffer2 = pins.createBuffer(3)" line16="        buffer2[0] = 0x00" line17="        buffer2[1] = cmd1" line18="        buffer2[2] = cmd2" line19="        pins.i2cWriteBuffer(ADDR, buffer2)" line20="    }" line21="    // From microbit/micropython Chinese community" line22="    function cmd3(cmd1: number, cmd2: number, cmd3: number): void {" line23="        let buffer3 = pins.createBuffer(4)" line24="        buffer3[0] = 0x00" line25="        buffer3[1] = cmd1" line26="        buffer3[2] = cmd2" line27="        buffer3[3] = cmd3" line28="        pins.i2cWriteBuffer(ADDR, buffer3)" line29="    }" line30="    function showbit(bit: number, shift: number): number {" line31="        if (bit &amp; (1 &lt;&lt; shift)) { }" line32="        else {" line33="            bit += 1 &lt;&lt; shift" line34="        }" line35="        return bit" line36="    }" line37="    function hidebit(bit: number, shift: number): number {" line38="        if (bit &amp; (1 &lt;&lt; shift)) {" line39="            bit -= 1 &lt;&lt; shift" line40="        }" line41="        return bit" line42="    }" line43="    function getbit(bits: number, shift: number): number {" line44="        return (bits &gt;&gt; shift) &amp; 1;" line45="    }" line46="    /**" line47="     * Initialize OLED display, this command must be called at the start of the program." line48="     */" line49="    //% block=&quot;init OLED display&quot;" line50="    //% weight=101" line51="    export function init(): void {" line52="        screen = pins.createBuffer(1025)" line53="        cmd1(0xAE)" line54="        cmd1(0xA4)" line55="        cmd2(0xD5, 0xF0)" line56="        cmd2(0xA8, 0x3F)" line57="        cmd2(0xD3, 0x00)" line58="        cmd1(0x0)" line59="        cmd2(0x8D, 0x14)" line60="        cmd2(0x20, 0x00)" line61="        cmd3(0x21, 0x0, 0x7F)" line62="        cmd3(0x22, 0x0, 0x3F)" line63="        cmd1(0xa1)" line64="        cmd1(0xC8)" line65="        cmd2(0xDA, 0x12)" line66="        cmd2(0x81, 0xFF)" line67="        cmd2(0xD9, 0xF1)" line68="        cmd2(0xDB, 0x40)" line69="        cmd1(0xA6)" line70="        cmd2(0xD6, 0x0)" line71="        cmd1(0xAF)" line72="        clear(false)" line73="        draw()" line74="    }" line75="    /**" line76="     * Fills the display buffer with specified color." line77="     * You need to call `draw` to see the changes." line78="     * @param color filling color (usually `false`)" line79="     */" line80="    //% block=&quot;clear $color&quot;" line81="    //% color.defl=false" line82="    //% weight=99" line83="    export function clear(color: boolean): void {" line84="        screen.fill((color) ? 0xFF : 0)" line85="    }" line86="    /**" line87="     * Sends buffer to OLED display." line88="     * This command must be called whenever you want to show something on the OLED display." line89="     */" line90="    //% block=&quot;draw&quot;" line91="    //% weight=98" line92="    export function draw(): void {" line93="        pins.i2cWriteNumber(ADDR, 0xB0, NumberFormat.UInt16BE)" line94="        pins.i2cWriteNumber(ADDR, 0x00, NumberFormat.UInt16BE)" line95="        pins.i2cWriteNumber(ADDR, 0x10, NumberFormat.UInt16BE)" line96="        screen[0] = 0x40" line97="        pins.i2cWriteBuffer(ADDR, screen, false)" line98="    }" line99="    /**" line100="     * Sets pixel at x y to specified color color." line101="     * You need to call `draw` to see the changes." line102="     * @param x coordinate x (increases towards the right)" line103="     * @param y coordinate y (increases downwards)" line104="     * @param color color of pixel" line105="     */" line106="    //% block=&quot;set pixel at x $x y $y to $color&quot;" line107="    //% color.defl=true" line108="    //% weight=97" line109="    export function setPx(x: number, y: number, color: boolean): void {" line110="        const index = Math.round(Math.floor(y / 8) * 128 + x + 1)" line111="        if ((index &lt; 1025) &amp;&amp; (index &gt; -1) &amp;&amp; (x &lt; 128) &amp;&amp; (x &gt; -1) &amp;&amp; (y &gt; -1) &amp;&amp; (y &lt; 128)) {" line112="            screen[index] = (color) ? showbit(screen[index], (y % 8)) : hidebit(screen[index], (y % 8))" line113="        }" line114="    }" line115="    /**" line116="     * Toggles pixel at x y, it means that `true` will be `false` and vice versa." line117="     * You need to call `draw` to see the changes." line118="     * @param x coordinate x (increases towards the right)" line119="     * @param y coordinate y (increases downwards)" line120="     */" line121="    //% block=&quot;toggle pixel at x $x y $y&quot;" line122="    //% weight=96" line123="    export function togglePx(x: number, y: number): void {" line124="        const index2 = Math.round(Math.floor(y / 8) * 128 + x + 1)" line125="        if ((index2 &lt; 1025) &amp;&amp; (index2 &gt; -1) &amp;&amp; (x &lt; 128) &amp;&amp; (x &gt; -1) &amp;&amp; (y &gt; -1) &amp;&amp; (y &lt; 128)) {" line126="            screen[index2] = (!px(x, y)) ? showbit(screen[index2], (y % 8)) : hidebit(screen[index2], (y % 8))" line127="        }" line128="    }" line129="    /**" line130="     * Returns color of pixel at x y in buffer." line131="     * @param x coordinate x (increases towards the right)" line132="     * @param y coordinate y (increases downwards)" line133="     */" line134="    //% block=&quot;pixel at x $x y $y&quot;" line135="    //% weight=95" line136="    export function px(x: number, y: number): boolean {" line137="        const index3 = Math.round(Math.floor(y / 8) * 128 + x + 1)" line138="        if ((index3 &lt; 1025) &amp;&amp; (index3 &gt; -1) &amp;&amp; (x &lt; 128) &amp;&amp; (x &gt; -1) &amp;&amp; (y &gt; -1) &amp;&amp; (y &lt; 128)) {" line139="            return getbit(screen[index3], (y % 8)) == 1" line140="        } else {" line141="            return false" line142="        }" line143="    }" line144="    /**" line145="     * Draws text with upper left corner at x y." line146="     * Text has fixed width (8 px)." line147="     * You need to call `draw` to see the changes." line148="     * @param text text to draw (not all characters are implemented yet)" line149="     * @param x coordinate x of upper left corner of text (increases towards the right)" line150="     * @param y coordinate y of upper left corner of text (increases downwards)" line151="     * @param color color of text" line152="     */" line153="    //% block=&quot;draw text $text at|x $x|y $y|color $color|toggle $toggle&quot;" line154="    //% color.defl=true" line155="    //% toggle.defl=false" line156="    //% weight=94" line157="    export function drawText(text: string, x: number, y: number, color: boolean, toggle: boolean): void {" line158="        const font = [" line159="            [0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]," line160="            [0x00, 0x10, 0x10, 0x10, 0x10, 0x10, 0x00, 0x10, 0x10, 0x00, 0x00]," line161="            [0x24, 0x24, 0x24, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]," line162="            [0x00, 0x24, 0x24, 0x7E, 0x24, 0x7E, 0x24, 0x24, 0x00, 0x00, 0x00]," li