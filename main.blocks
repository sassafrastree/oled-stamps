, 0x10, 0x10, 0x0C, 0x00]," line254="            [0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x00]," line255="            [0x30, 0x08, 0x08, 0x10, 0x0C, 0x10, 0x08, 0x08, 0x08, 0x30, 0x00]," line256="            [0x00, 0x00, 0x00, 0x32, 0x4C, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]" line257="        ]" line258="        let line = 0" line259="        let lineStart = 0" line260="        for (let i = 0; i &lt; text.length; i++) {" line261="            if (text[i] == '\n') {" line262="                line++" line263="                lineStart = i + 1" line264="            } else if (charsetIndex.indexOf(text[i]) !== -1) {" line265="                for (let j = 0; j &lt; 11; j++) {" line266="                    for (let k = 0; k &lt; 8; k++) {" line267="                        if (charset[charsetIndex.indexOf(text[i])][j] &amp; (0x01 &lt;&lt; k)) {" line268="                            if (toggle) {" line269="                                togglePx(x + ((i - lineStart) * 8) + (8 - k), y + (line * 10) + j)" line270="                            } else {" line271="                                setPx(x + ((i - lineStart) * 8) + (8 - k), y + (line * 10) + j, color)" line272="                            }" line273="                        }" line274="                    }" line275="                }" line276="            } else if (text[i].charCodeAt(0) &lt; 128 &amp;&amp; text[i].charCodeAt(0) &gt;= 32) {" line277="                for (let l = 0; l &lt; 11; l++) {" line278="                    for (let m = 0; m &lt; 8; m++) {" line279="                        if (font[text[i].charCodeAt(0) - 32][l] &amp; (0x01 &lt;&lt; m)) {" line280="                            if (toggle) {" line281="                                togglePx(x + ((i - lineStart) * 8) + (8 - m), y + (line * 10) + l)" line282="                            } else {" line283="                                setPx(x + ((i - lineStart) * 8) + (8 - m), y + (line * 10) + l, color)" line284="                            }" line285="                        }" line286="                    }" line287="                }" line288="            } else {" line289="            }" line290="            basic.pause(1)" line291="        }" line292="        draw()" line293="    }" line294="    /**" line295="     * Draws image." line296="     * You need to call `draw` to see the changes." line297="     * @param image image to draw (can be `images.createImage()` or image from extension `imageio`)" line298="     * @param x coordinate x of upper left corner of image (increases towards the right)" line299="     * @param y coordinate y of upper left corner of image (increases downwards)" line300="     */" line301="    //% block=&quot;draw image |$image|x $x|y $y&quot;" line302="    //% weight=100" line303="    export function drawImage(image: Image, x: number, y: number): void {" line304="        if ((image != null) &amp;&amp; (image != undefined)) {" line305="            let scale = 4" line306="            if (image.width() == 16) {" line307="                scale = 8" line308="            }" line309="            for (let img_y = 0; img_y &lt; image.width() * scale; img_y++) {" line310="                for (let img_x = 0; img_x &lt; image.height() * scale; img_x++) {" line311="                    let c = image.pixel(img_x, img_y)" line312="                    for (let y_scale = 0; y_scale &lt; scale; y_scale++) {" line313="                        for (let x_scale = 0; x_scale &lt; scale; x_scale++) {" line314="                            if (c) {" line315="                                setPx(x + img_x * scale - x_scale + scale, y + img_y * scale - y_scale + scale, c)" line316="                            }" line317="                        }" line318="                    }" line319="                }" line320="            }" line321="            basic.pause(1)" line322="        }" line323="        draw()" line324="    }" line325="    /**" line326="     */" line327="    //% block=&quot;image: 32x16&quot;" line328="    //% advanced=true" line329="    //% shim=images::createImage" line330="    //% imageLiteral=1 imageLiteralRows=16 imageLiteralColumns=32" line331="    export function imageMap32(leds: string): Image {" line332="        return &lt;Image&gt;&lt;any&gt;leds" line333="    }" line334="    /**" line335="     */" line336="    //% block=&quot;image: 16x8&quot;" line337="    //% shim=images::createImage" line338="    //% imageLiteral=1 imageLiteralRows=8 imageLiteralColumns=16" line339="    export function imageMap16(leds: string): Image {" line340="        return &lt;Image&gt;&lt;any&gt;leds" line341="    }" line342="}" numlines="343"></mutation></block></statement></block></xml>